{
  "name": "@archastro/channel-harness",
  "version": "0.1.1",
  "description": "Runtime contract-testing harness for Phoenix channels declared in an OpenAPI spec (via x-channels).",
  "keywords": [
    "openapi",
    "phoenix",
    "channels",
    "websocket",
    "contract-testing",
    "archastro"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArchAstro/archastro-openapi.git",
    "directory": "packages/channel-harness"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./bin": "./dist/bin.js"
  },
  "bin": {
    "channel-harness": "dist/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@archastro/sdk-generator": "^0.1.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "ws": "^8.18.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.4.0",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}
