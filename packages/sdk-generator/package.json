{
  "name": "@archastro/sdk-generator",
  "version": "0.1.3",
  "description": "Generate typed TypeScript and Python SDKs (plus contract tests) from an OpenAPI spec.",
  "keywords": [
    "openapi",
    "sdk",
    "codegen",
    "typescript",
    "python",
    "archastro"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArchAstro/archastro-openapi.git",
    "directory": "packages/sdk-generator"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "sdk-generator": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "node ./scripts/run-tests.mjs",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}
